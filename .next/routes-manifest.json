{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/bahan-baku/[id]",
      "regex": "^/api/bahan\\-baku/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/bahan\\-baku/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/cabang/[id]",
      "regex": "^/api/cabang/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/cabang/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/menu/[id]",
