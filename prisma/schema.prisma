generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nama      String
  role      String
  cabangId  String?
  cabang    Cabang?  @relation(fields: [cabangId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  avatar    String?
  transaksi Transaksi[]
}

model Cabang {
  id        String   @id @default(cuid())
  nama      String
  alamat    String?
  telepon   String?
  createdAt DateTime @default(now())
  bahanBaku BahanBaku[]
  users     User[]
  menus     Menu[]
}

model BahanBaku {
  id        String   @id @default(cuid())
  nama      String
  rasa      String?
  berat     Int
  stok      Int
  satuan    String   @default("pcs")
  gambar    String?
  deskripsi String?
  jenisProduk String   @default("Makanan")
  cabangId  String
  cabang    Cabang   @relation(fields: [cabangId], references: [id], onDelete: Cascade)
  reseps    Resep[]
  createdAt DateTime @default(now())
}

model Menu {
  id          String   @id @default(cuid())
  nama        String
  kategori   String
  harga       Int
  hargaBeli   Int?
  tersedia   Boolean  @default(true)
  gambar     String?
  deskripsi   String?
  createdAt  DateTime  @default(now())
  resep       Resep[]
  cabangId    String?
  cabang      Cabang?   @relation(fields: [cabangId], references: [id], onDelete: SetNull)
  cartItems   CartItem[]
}

model Resep {
  id          String   @id @default(cuid())
  menuId      String
  bahanBakuId String
  jumlah      Int
  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  bahanBaku   BahanBaku @relation(fields: [bahanBakuId], references: [id], onDelete: Cascade)
}

model Transaksi {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtotal          Int
  pajak             Int
  total             Int
  metodePembayaran  String
  bayar             Int
  kembalian         Int
  catatan          String?
  keterangan       String?
  buktiPembayaran  String?
  buktiPenjualan  String?
  tanggal          DateTime   @default(now())
  items            CartItem[]
}

model CartItem {
  id          String    @id @default(cuid())
  transaksiId String
  menuId      String
  nama       String
  kategori   String
  harga      Int
  jumlah     Int
  transaksi  Transaksi @relation(fields: [transaksiId], references: [id], onDelete: Cascade)
  menu       Menu      @relation(fields: [menuId], references: [id])
}

